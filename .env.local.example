# ============================================================
# hypnovital – Environment Variables
# ============================================================
# Kopiere diese Datei nach .env.local und trage deine Werte ein

# -------- Stripe --------
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs (in Stripe Dashboard erstellen)
STRIPE_PRICE_ABNEHMEN=price_...
STRIPE_PRICE_RAUCHFREI=price_...
STRIPE_PRICE_ENTSPANNEN=price_...
STRIPE_PRICE_SELBSTVERTRAUEN=price_...
STRIPE_PRICE_LAMPENFIEBER=price_...
STRIPE_PRICE_ORGASMUS=price_...

# -------- Resend --------
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@hypnovital.ch
ADMIN_NOTIFICATION_EMAIL=info@hypnovital.ch

# -------- Sanity CMS --------
NEXT_PUBLIC_SANITY_PROJECT_ID=xxxxxxxx
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01
SANITY_API_TOKEN=skxxxxxxxx

# -------- Supabase Storage (für MP3-Dateien) --------
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# -------- App --------
NEXT_PUBLIC_SITE_URL=http://localhost:3000
DOWNLOAD_BASE_URL=https://xxx.supabase.co/storage/v1/object/sign/audio
